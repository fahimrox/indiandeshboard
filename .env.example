# UPSTOX CREDENTIALS (PRIMARY MARKET DATA)
UPSTOX_ACCESS_TOKEN=your_upstox_access_token_here

# ANGEL ONE CREDENTIALS (BACKUP MARKET DATA & OPTION CHAIN)
ANGEL_ONE_CLIENT_ID=your_angel_one_client_id_here
ANGEL_ONE_MPIN=your_angel_one_mpin_here
ANGEL_ONE_API_KEY=your_angel_one_api_key_here
ANGEL_ONE_TOTP_SECRET=your_angel_one_totp_secret_here

# SECURE SERVER CONFIG
# Optional: Secret key used to encrypt the Fyers Access Token when saved on the server's disk.
ENCRYPTION_KEY=lovable-indian-dashboard-salt-12345

# FYERS CREDENTIALS (OPTION CHAIN SOURCE)
# client_id aur secret_key Fyers developer portal se milte hain
# generate_token.py in variables ko .env se read karta hai
FYERS_CLIENT_ID=your_fyers_client_id_here
FYERS_SECRET_KEY=your_fyers_secret_key_here
